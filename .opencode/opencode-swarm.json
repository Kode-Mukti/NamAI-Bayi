{
  "$schema": "https://opencode.ai/config.json",
  "project_type": "android",
  "qa_gates": {
    "reviewer": true,
    "test_engineer": true,
    "sast_enabled": true,
    "drift_check": true
  },
  "agents": {
    "architect": {
      "model": "opencode/big-pickle",
      "temperature": 0.1
    },
    "coder": {
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.2,
      "authority": {
        "rules": ["src/**", "app/**", "*.gradle.kts", "gradle/**"]
      }
    },
    "reviewer": {
      "model": "opencode/big-pickle",
      "temperature": 0.1
    },
    "explorer": {
      "model": "opencode/big-pickle",
      "temperature": 0.1
    },
    "test_engineer": {
      "model": "opencode/gpt-5-nano",
      "temperature": 0.2
    },
    "sme": {
      "model": "opencode/big-pickle",
      "temperature": 0.2
    },
    "critic": {
      "model": "opencode/big-pickle",
      "temperature": 0.1
    },
    "docs": {
      "model": "opencode/big-pickle",
      "temperature": 0.2
    },
    "spec_writer": {
      "model": "opencode/big-pickle",
      "temperature": 0.2
    }
  },
  "max_iterations": 8,
  "memory": {
    "enabled": true,
    "auto_compact": true
  },
  "pr_monitor": {
    "enabled": false
  },
  "external_skills": {
    "curation_enabled": false
  },
  "steering": {
    "architecture_docs": "architecture/"
  }
}
